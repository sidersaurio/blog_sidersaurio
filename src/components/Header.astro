---
import HeaderLink from './HeaderLink.astro';
import ThemeToggle from './ThemeToggle.astro';
import { SITE_TITLE } from '../consts';
---

<header>
  <nav aria-label="Main navigation">
    <a href="/" class="site-title" aria-label={`${SITE_TITLE} — home`}>
      {SITE_TITLE}
    </a>

    <div class="nav-links">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
    </div>

    <div class="nav-end">
      <ThemeToggle />
      <div class="social-links">
        <a href="https://discord.gg/astro" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Join Astro on Discord</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
            <path fill="currentColor" d="M20.317 4.3671a19.8062 19.8062 0 00-4.8851-1.5152.074.074 0 00-.0784.0365c-.211.3667-.4429.8458-.6072 1.2237a18.869 18.869 0 00-5.6125 0c-.1632-.3933-.4006-.8571-.6247-1.2237a.077.077 0 00-.0785-.0365 19.7818 19.7818 0 00-4.8854 1.515.0683.0683 0 00-.0319.0271C.3534 9.046-.213 13.6026.0656 18.1313a.092.092 0 00.0396.0605c2.0653 1.6235 4.0693 2.6115 6.0428 3.272a.078.078 0 00.084-.0281c.461-.6147.872-1.263 1.221-1.9435a.074.074 0 00-.041-.1037c-.641-.2427-1.251-.5353-1.835-.8779a.075.075 0 00-.008-.1256c.123-.0923.246-.1897.365-.2831a.074.074 0 00.076-.0105c3.858 1.7625 8.037 1.7625 11.861 0a.075.075 0 00.076.0104c.119.0934.242.1908.365.2832a.075.075 0 00-.006.1255c-.584.3426-1.195.6353-1.836.8779a.075.075 0 00-.041.1037c.35.681.761 1.3298 1.22 1.9435a.077.077 0 00.084.028c1.976-.6157 3.98-1.7044 6.046-3.272a.081.081 0 00.041-.0605c.317-4.6973-.531-8.7852-2.247-12.5253a.061.061 0 00-.032-.0271zM8.02 15.3312c-1.1825 0-2.1569-.9797-2.1569-2.1818 0-1.2022.9518-2.1819 2.1569-2.1819 1.2051 0 2.1779.9797 2.1569 2.1819 0 1.2021-.9518 2.1818-2.1569 2.1818zm7.9748 0c-1.1825 0-2.1569-.9797-2.1569-2.1818 0-1.2022.9518-2.1819 2.1569-2.1819 1.205 0 2.178.9797 2.1569 2.1819 0 1.2021-.953 2.1818-2.1569 2.1818Z"/>
          </svg>
        </a>
        <a href="https://twitter.com/astrodotbuild" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Follow Astro on X</span>
          <svg viewBox="0 0 24 24" aria-hidden="true" width="22" height="22">
            <path fill="currentColor" d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.6l-5.1-6.72-5.95 6.72H2.42l7.75-8.835L1.254 2.25h6.554l4.6 6.08 5.436-6.08zM17.534 20.5h1.833L6.455 4.109H4.482l13.052 16.391z"/>
          </svg>
        </a>
        <a href="https://github.com/withastro/astro" target="_blank" rel="noopener noreferrer">
          <span class="sr-only">Go to Astro&apos;s GitHub repo</span>
          <svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22">
            <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
          </svg>
        </a>
      </div>
    </div>
  </nav>
</header>

<style>
  header {
    position: sticky;
    top: 0;
    z-index: 50;
    background-color: var(--gm-surface);
    border-bottom: 1px solid var(--gm-border);
    padding: 0 1.5rem;
    transition: background-color 0.25s ease, border-color 0.25s ease;
  }

  @media (prefers-reduced-motion: reduce) {
    header { transition: none; }
  }

  nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    height: 3.5rem;
    max-width: 960px;
    margin: 0 auto;
  }

  .site-title {
    font-size: 1rem;
    font-weight: 700;
    color: var(--gm-text);
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .site-title:hover {
    color: var(--gm-accent);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }

  .nav-end {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .social-links {
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    color: var(--gm-muted);
    text-decoration: none;
    padding: 0.25rem;
    border-radius: var(--gm-radius-xs);
    transition: color 0.15s ease;
  }

  .social-links a:hover {
    color: var(--gm-accent);
  }

  @media (max-width: 640px) {
    .social-links { display: none; }
    .nav-links { justify-content: flex-start; }
  }
</style>
