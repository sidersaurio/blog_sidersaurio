---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const recentPosts = allPosts.slice(0, 3).sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>

	<body>
		<Header />
		<main>
			<!-- Hero Section -->
			<section class="hero">
				<div class="container">
					<div class="hero-content">
						<h1 class="gradient-text">El Blog del Sidersaurio</h1>
						<p class="hero-subtitle">Explorando el mundo de la tecnología, desarrollo web y más.</p>
						<div class="hero-buttons">
							<a href="/blog" class="btn btn-primary">Explorar Blog</a>
							<a href="/contact" class="btn btn-secondary">Contacto</a>
						</div>
					</div>
					<div class="hero-visual">
						<div class="code-block">
							<div class="code-header">
								<span class="code-dot code-dot-red"></span>
								<span class="code-dot code-dot-yellow"></span>
								<span class="code-dot code-dot-green"></span>
							</div>
							<pre><code>{"// Welcome to our blog\nconst passion = \"Technology\";\nconst focus = \"Web Development\";\n\nconsole.log(\"Let's build something amazing!\");"}</code></pre>
						</div>
					</div>
				</div>
			</section>

			<!-- Featured Posts Section -->
			<section class="featured-posts">
				<div class="container">
					<div class="section-header">
						<h2>Últimas Publicaciones</h2>
						<p>Descubre nuestros artículos más recientes</p>
					</div>

					{recentPosts.length > 0 ? (
						<div class="posts-grid">
							{recentPosts.map((post) => (
								<article class="post-card">
									{post.data.heroImage && (
										<div class="post-image">
											<img src={typeof post.data.heroImage === 'string' ? post.data.heroImage : post.data.heroImage.src} alt={post.data.title} />
										</div>
									)}
									<div class="post-content">
										<h3>{post.data.title}</h3>
										<p class="post-description">{post.data.description}</p>
										<time class="post-date">
											{new Date(post.data.pubDate).toLocaleDateString('es-ES')}
										</time>
										<a href={`/blog/${post.slug}`} class="read-more">Leer más →</a>
									</div>
								</article>
							))}
						</div>
					) : (
						<p class="no-posts">No hay publicaciones disponibles aún.</p>
					)}
				</div>
			</section>

			<!-- CTA Section -->
			<section class="cta-section">
				<div class="container">
					<h2>¿Quieres aprender más?</h2>
					<p>Síguenos y no te pierdas ningún artículo nuevo</p>
					<div class="cta-buttons">
						<a href="/auth/signup" class="btn btn-primary">Crear Cuenta</a>
						<a href="/blog" class="btn btn-secondary">Explorar Blog</a>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.hero {
		min-height: 100vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 4rem 1rem;
		background: linear-gradient(135deg, oklch(0.5924 0.2025 355.8943 / 0.1) 0%, oklch(0.5808 0.1732 39.5003 / 0.1) 100%);
		border-bottom: 1px solid var(--border);
	}

	.hero .container {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 4rem;
		align-items: center;
	}

	.hero-content h1 {
		font-size: 4rem;
		margin-bottom: 1.5rem;
		line-height: 1.2;
	}

	.hero-subtitle {
		font-size: 1.25rem;
		color: var(--muted-foreground);
		margin-bottom: 2rem;
		line-height: 1.6;
	}

	.hero-buttons {
		display: flex;
		gap: 1rem;
		flex-wrap: wrap;
	}

	.btn {
		padding: 0.875rem 2rem;
		border-radius: var(--radius);
		font-weight: 600;
		text-decoration: none;
		transition: var(--transition);
		display: inline-block;
		font-size: 1rem;
	}

	.btn-primary {
		background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
		color: var(--primary-foreground);
		box-shadow: var(--shadow-md);
	}

	.btn-primary:hover {
		transform: translateY(-2px);
		box-shadow: var(--shadow-xl);
		text-decoration: none;
		color: var(--primary-foreground);
	}

	.btn-secondary {
		background: var(--card);
		color: var(--foreground);
		border: 1px solid var(--border);
	}

	.btn-secondary:hover {
		background: var(--muted);
		border-color: var(--primary);
		transform: translateY(-2px);
		text-decoration: none;
	}

	.hero-visual {
		display: flex;
		justify-content: center;
		align-items: center;
	}

	.code-block {
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		padding: 1rem;
		width: 100%;
		max-width: 450px;
		box-shadow: var(--shadow-lg);
	}

	.code-header {
		display: flex;
		gap: 0.5rem;
		margin-bottom: 1rem;
	}

	.code-dot {
		width: 0.75rem;
		height: 0.75rem;
		border-radius: 50%;
		display: block;
	}

	.code-dot-red {
		background: var(--destructive);
	}

	.code-dot-yellow {
		background: var(--accent);
	}

	.code-dot-green {
		background: var(--secondary);
	}

	.code-block pre {
		background: transparent;
		border: none;
		padding: 0;
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.6;
	}

	.code-block code {
		background: transparent;
		padding: 0;
		color: var(--secondary);
		font-family: var(--font-mono);
	}

	.featured-posts {
		padding: 6rem 1rem;
		background: var(--background);
	}

	.section-header {
		text-align: center;
		margin-bottom: 4rem;
	}

	.section-header h2 {
		font-size: 2.5rem;
		margin-bottom: 0.5rem;
	}

	.section-header p {
		font-size: 1.125rem;
		color: var(--muted-foreground);
	}

	.posts-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
		gap: 2rem;
	}

	.post-card {
		background: var(--card);
		border: 1px solid var(--border);
		border-radius: var(--radius);
		overflow: hidden;
		transition: var(--transition);
		display: flex;
		flex-direction: column;
	}

	.post-card:hover {
		transform: translateY(-4px);
		border-color: var(--primary);
		box-shadow: var(--shadow-xl);
	}

	.post-image {
		width: 100%;
		height: 200px;
		overflow: hidden;
		background: var(--muted);
	}

	.post-image img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		transition: var(--transition);
	}

	.post-card:hover .post-image img {
		transform: scale(1.05);
	}

	.post-content {
		padding: 1.5rem;
		display: flex;
		flex-direction: column;
		flex-grow: 1;
	}

	.post-content h3 {
		font-size: 1.25rem;
		margin-bottom: 0.75rem;
		color: var(--foreground);
	}

	.post-description {
		color: var(--muted-foreground);
		margin-bottom: 1rem;
		font-size: 0.95rem;
		flex-grow: 1;
	}

	.post-date {
		font-size: 0.85rem;
		color: var(--muted);
		margin-bottom: 1rem;
		display: block;
	}

	.read-more {
		color: var(--primary);
		text-decoration: none;
		font-weight: 600;
		font-size: 0.95rem;
		transition: var(--transition);
	}

	.read-more:hover {
		color: var(--accent);
		text-decoration: none;
	}

	.no-posts {
		text-align: center;
		color: var(--muted-foreground);
		padding: 2rem;
	}

	.cta-section {
		background: linear-gradient(135deg, var(--primary) 0%, var(--accent) 100%);
		color: var(--primary-foreground);
		padding: 6rem 1rem;
		text-align: center;
	}

	.cta-section h2 {
		font-size: 2.5rem;
		color: var(--primary-foreground);
		margin-bottom: 0.75rem;
	}

	.cta-section p {
		font-size: 1.25rem;
		color: oklch(1.0000 0 0 / 0.9);
		margin-bottom: 2rem;
	}

	.cta-buttons {
		display: flex;
		gap: 1rem;
		justify-content: center;
		flex-wrap: wrap;
	}

	.cta-section .btn-primary {
		background: var(--primary-foreground);
		color: var(--primary);
		box-shadow: var(--shadow-lg);
	}

	.cta-section .btn-primary:hover {
		background: oklch(1.0000 0 0 / 0.95);
		text-decoration: none;
		color: var(--primary);
	}

	.cta-section .btn-secondary {
		background: oklch(1.0000 0 0 / 0.2);
		color: var(--primary-foreground);
		border: 1px solid oklch(1.0000 0 0 / 0.3);
	}

	.cta-section .btn-secondary:hover {
		background: oklch(1.0000 0 0 / 0.3);
		border-color: var(--primary-foreground);
		text-decoration: none;
	}

	@media (max-width: 768px) {
		.hero .container {
			grid-template-columns: 1fr;
			gap: 2rem;
		}

		.hero {
			min-height: auto;
			padding: 3rem 1rem;
		}

		.hero-content h1 {
			font-size: 2.5rem;
		}

		.hero-subtitle {
			font-size: 1rem;
		}

		.section-header h2 {
			font-size: 1.875rem;
		}

		.cta-section h2 {
			font-size: 1.875rem;
		}

		.featured-posts {
			padding: 3rem 1rem;
		}

		.cta-section {
			padding: 3rem 1rem;
		}
	}
</style>
