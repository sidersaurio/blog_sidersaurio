---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .hero {
        padding: 3rem 0 1.5rem;
        text-align: center;
      }

      .hero h1 {
        font-size: clamp(2rem, 6vw, 3.5rem);
        margin-bottom: 1rem;
        color: var(--gm-text);
      }

      .hero h1 span {
        color: var(--gm-accent);
      }

      .hero p {
        font-size: 1.1rem;
        color: var(--gm-muted);
        max-width: 52ch;
        margin: 0 auto 2rem;
        line-height: 1.7;
      }

      .pill-list {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        justify-content: center;
        list-style: none;
        margin: 0 0 3rem;
        padding: 0;
      }

      .pill {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.35rem 0.9rem;
        font-size: 0.875rem;
        font-weight: 600;
        border-radius: 999px;
        border: 2px solid var(--gm-border);
        color: var(--gm-muted);
        background-color: var(--gm-surface);
        white-space: nowrap;
      }

      .pill-accent { border-color: var(--gm-accent); color: var(--gm-accent); }
      .pill-coral  { border-color: var(--gm-coral);  color: var(--gm-coral);  }
      .pill-amber  { border-color: var(--gm-amber);  color: var(--gm-amber);  }
      .pill-mint   { border-color: var(--gm-mint);   color: var(--gm-mint);   }

      .card-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(min(280px, 100%), 1fr));
        gap: 1.25rem;
        margin-top: 1rem;
      }

      .card {
        background-color: var(--gm-surface);
        border: 1px solid var(--gm-border);
        border-radius: var(--gm-radius);
        padding: 1.5rem;
        transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
      }

      .card:hover {
        border-color: var(--gm-accent);
        box-shadow:
          0 4px 0 0 var(--gm-shadow),
          0 8px 24px 0 oklch(0% 0 0 / 16%);
        transform: translateY(-2px);
      }

      @media (prefers-reduced-motion: reduce) {
        .card { transition: none; transform: none !important; }
      }

      .card h3 {
        font-size: 1rem;
        margin: 0 0 0.5rem 0;
        color: var(--gm-text);
      }

      .card p {
        font-size: 0.9rem;
        color: var(--gm-muted);
        margin: 0;
        line-height: 1.6;
      }

      .card code {
        font-size: 0.8rem;
      }

      .section-label {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        color: var(--gm-muted);
        margin: 0 0 1rem 0;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="hero">
        <h1>Hello, <span>Astronaut!</span></h1>
        <p>
          A minimal Astro blog starter — now dressed in the
          <strong>Gummies</strong> design system with seamless dark/light
          mode. Start here and make it yours.
        </p>
        <ul class="pill-list" aria-label="Tech stack">
          <li class="pill pill-accent">Astro 5</li>
          <li class="pill pill-coral">MDX</li>
          <li class="pill pill-amber">Tailwind CSS</li>
          <li class="pill pill-mint">Gummies DS</li>
        </ul>
      </div>

      <p class="section-label">Get started</p>
      <div class="card-grid">
        <div class="card">
          <h3>Edit this page</h3>
          <p>Open <code>src/pages/index.astro</code> and start customising your home page.</p>
        </div>
        <div class="card">
          <h3>Update the header</h3>
          <p>Change nav links in <code>src/components/Header.astro</code>.</p>
        </div>
        <div class="card">
          <h3>Write a post</h3>
          <p>Add Markdown or MDX files inside <code>src/content/blog/</code> to publish.</p>
        </div>
        <div class="card">
          <h3>Customise the theme</h3>
          <p>Edit the <code>--gm-*</code> tokens in <code>src/styles/global.css</code> to adjust colours.</p>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
