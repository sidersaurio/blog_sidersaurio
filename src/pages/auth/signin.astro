---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';
---

<html lang="en">
	<head>
		<BaseHead title={`Sign In - ${SITE_TITLE}`} description="Sign in to your account" />
	</head>

	<body>
		<Header />
		<main>
			<section class="auth-section">
				<div class="auth-container">
					<div class="auth-card">
						<h1>Welcome Back</h1>
						<p class="auth-subtitle">Sign in to your account</p>

						<form id="signin-form" class="auth-form">
							<div class="form-group">
								<label for="email">Email</label>
								<input type="email" id="email" name="email" required placeholder="your@email.com" />
							</div>

							<div class="form-group">
								<label for="password">Password</label>
								<input
									type="password"
									id="password"
									name="password"
									required
									placeholder="••••••••"
								/>
							</div>

							<button type="submit" class="btn-auth">Sign In</button>

							<div id="form-message" class="form-message"></div>
						</form>

						<div class="auth-links">
							<p>
								Don&apos;t have an account? <a href="/auth/signup">Sign Up</a>
							</p>
							<p>
								<a href="/auth/forgot-password">Forgot password?</a>
							</p>
						</div>
					</div>
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.auth-section {
		min-height: 80vh;
		display: flex;
		align-items: center;
		justify-content: center;
		padding: 2rem 1rem;
		background: linear-gradient(135deg, rgba(124, 58, 237, 0.05) 0%, rgba(59, 130, 246, 0.05) 100%);
	}

	.auth-container {
		width: 100%;
		max-width: 400px;
	}

	.auth-card {
		background: var(--bg-secondary);
		border: 1px solid var(--border-color);
		border-radius: 0.75rem;
		padding: 2.5rem;
		box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
	}

	.auth-card h1 {
		font-size: 1.875rem;
		margin-bottom: 0.5rem;
		color: var(--text-primary);
	}

	.auth-subtitle {
		color: var(--text-secondary);
		margin-bottom: 2rem;
		font-size: 0.95rem;
	}

	.auth-form {
		display: flex;
		flex-direction: column;
		gap: 1.5rem;
	}

	.form-group {
		display: flex;
		flex-direction: column;
		gap: 0.5rem;
	}

	.form-group label {
		font-weight: 600;
		color: var(--text-primary);
		font-size: 0.9rem;
	}

	.form-group input {
		background-color: var(--bg-tertiary);
		border: 1px solid var(--border-color);
		color: var(--text-primary);
		padding: 0.75rem 1rem;
		border-radius: 0.375rem;
		font-size: 1rem;
		font-family: 'Poppins', system-ui, sans-serif;
		transition: var(--transition);
	}

	.form-group input:focus {
		outline: none;
		border-color: var(--accent-purple);
		box-shadow: 0 0 0 3px rgba(124, 58, 237, 0.1);
	}

	.btn-auth {
		background: linear-gradient(135deg, var(--accent-purple) 0%, var(--accent-blue) 100%);
		color: white;
		padding: 0.875rem 1.5rem;
		border: none;
		border-radius: 0.375rem;
		font-weight: 600;
		font-size: 1rem;
		cursor: pointer;
		transition: var(--transition);
		width: 100%;
		margin-top: 0.5rem;
	}

	.btn-auth:hover {
		transform: translateY(-2px);
		box-shadow: 0 8px 25px rgba(124, 58, 237, 0.4);
	}

	.btn-auth:active {
		transform: translateY(0);
	}

	.btn-auth:disabled {
		opacity: 0.6;
		cursor: not-allowed;
		transform: none;
	}

	.form-message {
		padding: 0.75rem 1rem;
		border-radius: 0.375rem;
		display: none;
		font-size: 0.9rem;
		text-align: center;
	}

	.form-message.show {
		display: block;
	}

	.form-message.success {
		background-color: rgba(34, 197, 94, 0.1);
		color: #22c55e;
		border: 1px solid rgba(34, 197, 94, 0.3);
	}

	.form-message.error {
		background-color: rgba(239, 68, 68, 0.1);
		color: #ef4444;
		border: 1px solid rgba(239, 68, 68, 0.3);
	}

	.auth-links {
		display: flex;
		flex-direction: column;
		gap: 1rem;
		text-align: center;
		margin-top: 1.5rem;
	}

	.auth-links p {
		color: var(--text-secondary);
		font-size: 0.95rem;
		margin: 0;
	}

	.auth-links a {
		color: var(--accent-purple);
		text-decoration: none;
		font-weight: 600;
	}

	.auth-links a:hover {
		color: var(--accent-blue);
		text-decoration: underline;
	}

	@media (max-width: 480px) {
		.auth-card {
			padding: 1.5rem;
		}

		.auth-card h1 {
			font-size: 1.5rem;
		}
	}
</style>

<script>
	const form = document.getElementById('signin-form') as HTMLFormElement;
	const messageDiv = document.getElementById('form-message');

	if (form) {
		form.addEventListener('submit', async (e) => {
			e.preventDefault();

			const submitBtn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
			submitBtn.disabled = true;
			submitBtn.textContent = 'Signing In...';

			try {
				// In a real app, you would call an auth endpoint
				// For now, this is a placeholder
				messageDiv.textContent = 'Please configure authentication in your backend';
				messageDiv.className = 'form-message show error';
			} catch (error) {
				messageDiv.textContent = 'An error occurred. Please try again.';
				messageDiv.className = 'form-message show error';
				console.error('Sign in error:', error);
			} finally {
				submitBtn.disabled = false;
				submitBtn.textContent = 'Sign In';
			}
		});
	}
</script>
