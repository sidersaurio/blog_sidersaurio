---
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE, SITE_DESCRIPTION } from '../../consts';
import { getCollection } from 'astro:content';
import FormattedDate from '../../components/FormattedDate.astro';
import { Image } from 'astro:assets';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
    <style>
      .blog-grid {
        display: flex;
        flex-wrap: wrap;
        gap: 1.5rem;
        list-style: none;
        margin: 0;
        padding: 0;
      }

      /* Featured first post */
      .blog-grid li:first-child {
        width: 100%;
      }

      .blog-grid li:first-child .post-title {
        font-size: clamp(1.5rem, 4vw, 2.25rem);
      }

      /* Other posts */
      .blog-grid li {
        width: calc(50% - 0.75rem);
      }

      .post-card {
        display: block;
        text-decoration: none;
        border-radius: var(--gm-radius);
        border: 1px solid var(--gm-border);
        background-color: var(--gm-surface);
        overflow: hidden;
        transition:
          box-shadow 0.2s ease,
          border-color 0.2s ease,
          transform 0.2s ease;
      }

      .post-card:hover {
        border-color: var(--gm-accent);
        box-shadow:
          0 4px 0 0 var(--gm-shadow),
          0 8px 24px 0 oklch(0% 0 0 / 16%);
        transform: translateY(-2px);
      }

      @media (prefers-reduced-motion: reduce) {
        .post-card { transition: none; transform: none !important; }
      }

      .post-card img {
        width: 100%;
        height: auto;
        border-radius: 0;
        display: block;
      }

      .post-card-body {
        padding: 1rem 1.25rem 1.25rem;
      }

      .post-title {
        margin: 0 0 0.35rem 0;
        color: var(--gm-text);
        font-size: 1.1rem;
        font-weight: 700;
        line-height: 1.3;
      }

      .post-date {
        margin: 0;
        font-size: 0.825rem;
        color: var(--gm-muted);
      }

      @media (max-width: 640px) {
        .blog-grid li { width: 100%; }
        .blog-grid li:first-child .post-title { font-size: 1.5rem; }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <section aria-label="Blog posts">
        <ul class="blog-grid">
          {posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="post-card">
                {post.data.heroImage && (
                  <Image width={720} height={360} src={post.data.heroImage} alt="" />
                )}
                <div class="post-card-body">
                  <h4 class="post-title">{post.data.title}</h4>
                  <p class="post-date">
                    <FormattedDate date={post.data.pubDate} />
                  </p>
                </div>
              </a>
            </li>
          ))}
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>
